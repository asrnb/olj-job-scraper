{
  "manifest_version": 3,
  "name": "OnlineJobs.ph Job Scraper",
  "description": "Scrape latest job postings from OnlineJobs.ph based on a keyword.",
  "version": "2.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.onlinejobs.ph/*",
    "https://v2.onlinejobs.ph/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
